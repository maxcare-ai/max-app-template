# Database (Fly.io Postgres or local)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/my_app

# MaxCare Integration — API key from Developer Console
# Only needed if your app calls the MaxCare API directly (server-side)
MAXAI_API_KEY=ak_xxx
MAXAI_API_URL=https://api.maxcare.dev

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
