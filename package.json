{
  "name": "max-app-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "typeorm": "npx tsx ./node_modules/typeorm/cli.js -d src/lib/db/cli-data-source.ts",
    "db:migrate": "npm run typeorm -- migration:run",
    "db:migrate:revert": "npm run typeorm -- migration:revert",
    "db:migrate:generate": "npm run typeorm -- migration:generate",
    "db:migrate:create": "npm run typeorm -- migration:create",
    "db:sync": "npm run typeorm -- schema:sync",
    "dev:setup": "npm run db:up && sleep 2 && npm run db:sync && npm run dev",
    "postinstall": "cp node_modules/@max-ai/app-bridge/dist/app-bridge.iife.js public/app-bridge.iife.js 2>/dev/null || true"
  },
  "dependencies": {
    "@max-ai/app-bridge": "^0.0.4",
    "@max-ai/components": "^0.0.1",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reflect-metadata": "^0.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
